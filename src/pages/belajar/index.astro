---
// src/pages/belajar.astro
import Layout from "../../layouts/Layout.astro";
import Chat from "../../components/chat.svelte";
import ProfileSidebar from "../../components/ProfileSidebar.svelte";
import Navbar from "../../components/Navbar.astro";
---

<Layout
    title="Ruang Belajar - LENTERA"
    description="Interaksi langsung dengan AI Mentor LENTERA untuk membedah materi pelajaranmu."
>
    <main class="min-h-screen bg-[#F8FAFC] relative overflow-hidden selection:bg-[#6320EE]/10 selection:text-[#6320EE]">
        
        <div class="absolute -top-[10%] -left-[10%] w-[500px] h-[500px] bg-[#6320EE]/5 blur-[120px] rounded-full pointer-events-none"></div>
        <div class="absolute -bottom-[10%] -right-[10%] w-[600px] h-[600px] bg-[#C6F432]/10 blur-[150px] rounded-full pointer-events-none"></div>

        <Navbar />

        <div class="pt-32 pb-12 px-6 max-w-7xl mx-auto relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
                
                <aside class="lg:col-span-3 lg:sticky lg:top-32">
                    <ProfileSidebar client:load />
                </aside>

                <section class="lg:col-span-9">
                    <Chat client:load />
                </section>
                
            </div>
        </div>
    </main>
</Layout>