---
const testimonials = [
  {
    name: "Andi Pratama",
    role: "Orang Tua Siswa SMP",
    text: "LENTERA mengubah cara anak saya belajar Matematika. Analogi tentang pasar tradisional membuatnya mengerti konsep untung rugi dalam sekejap!",
    avatar: "👨‍💼",
    rating: 5
  },
  {
    name: "Siti Aminah",
    role: "Orang Tua Siswa SMA",
    text: "Sangat terbantu dengan fitur mentor AI-nya. Anak saya tidak lagi takut bertanya walau sudah tengah malam sekalipun.",
    avatar: "👩‍🏫",
    rating: 5
  },
  {
    name: "Budi Santoso",
    role: "Ayah dari 2 Anak",
    text: "Pendekatan kearifan lokalnya jempolan. Belajar Fisika jadi seru karena pakai contoh-contoh di sekitar rumah kami di desa.",
    avatar: "👨‍🌾",
    rating: 5
  }
];
---

<section class="py-32 px-6 bg-[#F1F5F9]/50">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-20">
      <span class="text-amber-500 font-bold tracking-widest uppercase text-xs mb-4 block">Testimonials</span>
      <h2 class="text-4xl md:text-6xl font-black text-slate-900 leading-tight">
        Listen to <span class="text-[#6320EE]">Parents'</span> Feedback
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map(t => (
        <div class="bg-white border border-slate-100 p-10 rounded-[3rem] shadow-sm hover:shadow-2xl hover:shadow-purple-600/5 transition-all duration-500 group">
          <div class="flex gap-1 mb-6">
            {[...Array(t.rating)].map(() => (
              <span class="text-amber-400">★</span>
            ))}
          </div>
          <p class="text-slate-600 italic text-lg leading-relaxed mb-10 font-medium">
            "{t.text}"
          </p>
          <div class="flex items-center gap-4 border-t border-slate-50 pt-8">
            <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-3xl shadow-sm group-hover:scale-110 transition-transform duration-500">
              {t.avatar}
            </div>
            <div>
              <h4 class="text-slate-900 font-bold">{t.name}</h4>
              <p class="text-slate-500 text-sm font-medium">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
